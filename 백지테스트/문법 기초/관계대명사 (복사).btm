    },
    {
      "id": "50wm83f1",
      "l": {
        "tag": "개념",
        "mark": "",
        "text": "목적격관계대명사는 관계대명사가 이끄는 절에서",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      },
      "r": {
        "tag": "",
        "mark": "",
        "text": "=> We saw a car ( which was fast ).",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      }
    },
    {
      "id": "3q6ist1s",
      "l": {
        "tag": "",
        "mark": "",
        "text": "목적어의 역할을 한다ss",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 1
      },
      "r": {
        "tag": "4",
        "mark": "",
        "text": "우리가 어제 만난 그 선생님은 착하다.",
        "vis": true,
        "bold": false,
        "hdr": false,
        "indent": 0
      }
    },
    {
      "id": "ls6kl8j8",
      "l": {
        "tag": "형태",
        "mark": "",
        "text": "- 선행사가 사람일 때 : who / whom",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      },
      "r": {
        "tag": "",
        "mark": "(1)",
        "text": "The teacher is kind.",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      }
    },
    {
      "id": "qpdix20m",
      "l": {
        "tag": "",
        "mark": "",
        "text": "- 선행사가 사람이 아닐 때 : whichss",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      },
      "r": {
        "tag": "",
        "mark": "(2)",
        "text": "We met the teacher yesterday.",
