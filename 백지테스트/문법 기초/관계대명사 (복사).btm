{
  "title": "관계대명사",
  "rows": [
    {
      "id": "0xkjiklr",
      "l": {
        "tag": "",
        "mark": "",
        "text": "SUMMARY",
        "vis": true,
        "bold": false,
        "hdr": true,
        "indent": 0
      },
      "r": {
        "tag": "",
        "mark": "",
        "text": "PRACTICE",
        "vis": true,
        "bold": false,
        "hdr": true,
        "indent": 0
      }
    },
    {
      "id": "2qqq83ts",
      "l": {
        "tag": "",
        "mark": "",
        "text": "관계대명사는 [접속사 + 대명사] 의 역할을 하며",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      },
      "r": {
        "tag": "",
        "mark": "",
        "text": "영작연습",
        "vis": true,
        "bold": true,
        "hdr": false,
        "indent": 0
      }
    },
    {
      "id": "sho0f62i",
      "l": {
        "tag": "",
        "mark": "",
        "text": "관계대명사가 이끄는 절은 앞의 명사(선행사)를 수식한다",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      },
      "r": {
        "tag": "1",
        "mark": "",
        "text": "나는 착한 소년을 안다.",
        "vis": true,
        "bold": false,
        "hdr": false,
        "indent": 0
      }
    },
    {
      "id": "f2597j9c",
      "l": {
        "tag": "",
        "mark": "",
        "text": "주격관계대명사",
        "vis": true,
        "bold": true,
        "hdr": false,
        "indent": 0
      },
      "r": {
        "tag": "",
        "mark": "(1)",
        "text": "I know a boy.",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      }
    },
    {
      "id": "2yjoolvp",
      "l": {
        "tag": "개념",
        "mark": "",
        "text": "주격관계대명사는 관계대명사가 이끄는 절에서",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      },
      "r": {
        "tag": "",
        "mark": "(2)",
        "text": "The boy is kind.",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      }
    },
    {
      "id": "csxe6h6u",
      "l": {
        "tag": "",
        "mark": "",
        "text": "주어의 역할을 한다",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 1
      },
      "r": {
        "tag": "",
        "mark": "",
        "text": "=> I know a boy ( who is kind ).",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      }
    },
    {
      "id": "r4r2gh59",
      "l": {
        "tag": "형태",
        "mark": "",
        "text": "- 선행사가 사람일 때 : who",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      },
      "r": {
        "tag": "2",
        "mark": "",
        "text": "그는 내가 믿는 친구를 가지고 있다.",
        "vis": true,
        "bold": false,
        "hdr": false,
        "indent": 0
      }
    },
    {
      "id": "etdpg3rw",
      "l": {
        "tag": "",
        "mark": "",
        "text": "- 선행사가 사람이 아닐 때 : which",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 1
      },
      "r": {
        "tag": "",
        "mark": "(1)",
        "text": "He has a friend.",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      }
    },
    {
      "id": "em78bnuw",
      "l": {
        "tag": "예문",
        "mark": "",
        "text": "She is a girl ( who likes pasta ).",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      },
      "r": {
        "tag": "",
        "mark": "(2)",
        "text": "I trust the friend.",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      }
    },
    {
      "id": "pbeydyci",
      "l": {
        "tag": "",
        "mark": "",
        "text": "선행사 (사람O)",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 1
      },
      "r": {
        "tag": "",
        "mark": "",
        "text": "=> He has a friend ( who(m) I trust ).",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      }
    },
    {
      "id": "holivapf",
      "l": {
        "tag": "예문",
        "mark": "",
        "text": "This is a house ( which is expensive ).",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      },
      "r": {
        "tag": "3",
        "mark": "",
        "text": "우리는 빠른 차를 봤다.",
        "vis": true,
        "bold": false,
        "hdr": false,
        "indent": 0
      }
    },
    {
      "id": "q32z66ui",
      "l": {
        "tag": "",
        "mark": "",
        "text": "선행사 (사람X)ZzZ",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 1
      },
      "r": {
        "tag": "",
        "mark": "(1)",
        "text": "We saw a car.",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
      }
    },
    {
      "id": "epogs5zw",
      "l": {
        "tag": "",
        "mark": "",
        "text": "목적격관계대명사sdfsdf",
        "vis": true,
        "bold": true,
        "hdr": false,
        "indent": 0
      },
      "r": {
        "tag": "",
        "mark": "(2)",
        "text": "The car was fast.",
        "vis": false,
        "bold": false,
        "hdr": false,
        "indent": 0
